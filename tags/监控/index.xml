<?xml version="1.0" encoding="utf-8" standalone="yes"?><rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom"><channel><title>监控 on</title><link>https://dlliang14.github.io/web-publicNotes/tags/%E7%9B%91%E6%8E%A7/</link><description>Recent content in 监控 on</description><generator>Hugo</generator><language>en</language><atom:link href="https://dlliang14.github.io/web-publicNotes/tags/%E7%9B%91%E6%8E%A7/index.xml" rel="self" type="application/rss+xml"/><item><title/><link>https://dlliang14.github.io/web-publicNotes/k8s-vm-grafana%E9%9B%86%E6%88%90/</link><pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate><guid>https://dlliang14.github.io/web-publicNotes/k8s-vm-grafana%E9%9B%86%E6%88%90/</guid><description>&lt;h1 id="k8s-vm-grafana集成"&gt;
 k8s-vm-grafana集成
 &lt;a class="anchor" href="#k8s-vm-grafana%e9%9b%86%e6%88%90"&gt;#&lt;/a&gt;
&lt;/h1&gt;
&lt;p&gt;[[k8s-使用vm监控]]&lt;/p&gt;
&lt;h2 id="安装参考"&gt;
 安装参考
 &lt;a class="anchor" href="#%e5%ae%89%e8%a3%85%e5%8f%82%e8%80%83"&gt;#&lt;/a&gt;
&lt;/h2&gt;
&lt;ul&gt;
&lt;li&gt;
&lt;a href="https://grafana.com/docs/grafana/latest/setup-grafana/installation/kubernetes/" rel="noopener"&gt;Grafana on Kubernetes&lt;/a&gt;&lt;/li&gt;
&lt;/ul&gt;
&lt;h2 id="部署步骤"&gt;
 部署步骤
 &lt;a class="anchor" href="#%e9%83%a8%e7%bd%b2%e6%ad%a5%e9%aa%a4"&gt;#&lt;/a&gt;
&lt;/h2&gt;
&lt;div class="highlight"&gt;&lt;pre tabindex="0" style="color:#f8f8f2;background-color:#272822;-moz-tab-size:4;-o-tab-size:4;tab-size:4;-webkit-text-size-adjust:none;"&gt;&lt;code class="language-bash" data-lang="bash"&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;kubectl create namespace my-grafana
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;kubectl apply -f grafana-all.yaml -n my-grafana
&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;ul&gt;
&lt;li&gt;默认访问：&lt;code&gt;http://&amp;lt;node-ip&amp;gt;:&amp;lt;nodeport&amp;gt;&lt;/code&gt;&lt;/li&gt;
&lt;li&gt;默认账号口令（首次登录后应立刻修改）：&lt;code&gt;admin/admin&lt;/code&gt;&lt;/li&gt;
&lt;/ul&gt;
&lt;h2 id="数据源配置"&gt;
 数据源配置
 &lt;a class="anchor" href="#%e6%95%b0%e6%8d%ae%e6%ba%90%e9%85%8d%e7%bd%ae"&gt;#&lt;/a&gt;
&lt;/h2&gt;
&lt;ul&gt;
&lt;li&gt;推荐把 VictoriaMetrics 作为 Prometheus 兼容数据源接入&lt;/li&gt;
&lt;li&gt;示例地址：&lt;code&gt;http://vmsingle-demo.vm:8428&lt;/code&gt;&lt;/li&gt;
&lt;li&gt;Grafana 中数据源类型选 &lt;code&gt;Prometheus&lt;/code&gt;，版本建议 &lt;code&gt;&amp;gt;= 2.24&lt;/code&gt;&lt;/li&gt;
&lt;/ul&gt;
&lt;h2 id="示例看板"&gt;
 示例看板
 &lt;a class="anchor" href="#%e7%a4%ba%e4%be%8b%e7%9c%8b%e6%9d%bf"&gt;#&lt;/a&gt;
&lt;/h2&gt;
&lt;ul&gt;
&lt;li&gt;
&lt;a href="https://grafana.com/grafana/dashboards/23382-nvidia-mig-dcgm/" rel="noopener"&gt;NVIDIA MIG DCGM Dashboard&lt;/a&gt;&lt;/li&gt;
&lt;/ul&gt;</description></item><item><title/><link>https://dlliang14.github.io/web-publicNotes/k8s-vm-operator%E5%AE%89%E8%A3%85/</link><pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate><guid>https://dlliang14.github.io/web-publicNotes/k8s-vm-operator%E5%AE%89%E8%A3%85/</guid><description>&lt;h1 id="k8s-vm-operator安装"&gt;
 k8s-vm-operator安装
 &lt;a class="anchor" href="#k8s-vm-operator%e5%ae%89%e8%a3%85"&gt;#&lt;/a&gt;
&lt;/h1&gt;
&lt;p&gt;[[k8s-使用vm监控]] | [[victoriametrics]]&lt;/p&gt;
&lt;h2 id="参考文档"&gt;
 参考文档
 &lt;a class="anchor" href="#%e5%8f%82%e8%80%83%e6%96%87%e6%a1%a3"&gt;#&lt;/a&gt;
&lt;/h2&gt;
&lt;ul&gt;
&lt;li&gt;
&lt;a href="https://docs.victoriametrics.com/operator/quick-start/" rel="noopener"&gt;VictoriaMetrics Operator Quick Start&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;
&lt;a href="https://victoriametrics.com/blog/vmagent-how-it-works/" rel="noopener"&gt;vmagent 工作原理&lt;/a&gt;&lt;/li&gt;
&lt;/ul&gt;
&lt;h2 id="安装-operator--crd"&gt;
 安装 Operator + CRD
 &lt;a class="anchor" href="#%e5%ae%89%e8%a3%85-operator--crd"&gt;#&lt;/a&gt;
&lt;/h2&gt;
&lt;div class="highlight"&gt;&lt;pre tabindex="0" style="color:#f8f8f2;background-color:#272822;-moz-tab-size:4;-o-tab-size:4;tab-size:4;-webkit-text-size-adjust:none;"&gt;&lt;code class="language-bash" data-lang="bash"&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;export VM_OPERATOR_VERSION&lt;span style="color:#f92672"&gt;=&lt;/span&gt;&lt;span style="color:#66d9ef"&gt;$(&lt;/span&gt;basename &lt;span style="color:#66d9ef"&gt;$(&lt;/span&gt;curl -fs -o /dev/null -w %&lt;span style="color:#f92672"&gt;{&lt;/span&gt;redirect_url&lt;span style="color:#f92672"&gt;}&lt;/span&gt; https://github.com/VictoriaMetrics/operator/releases/latest&lt;span style="color:#66d9ef"&gt;))&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;echo &lt;span style="color:#e6db74"&gt;&amp;#34;VM_OPERATOR_VERSION=&lt;/span&gt;$VM_OPERATOR_VERSION&lt;span style="color:#e6db74"&gt;&amp;#34;&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;wget -O operator-and-crds.yaml &lt;span style="color:#ae81ff"&gt;\
&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#e6db74"&gt;&amp;#34;https://github.com/VictoriaMetrics/operator/releases/download/&lt;/span&gt;$VM_OPERATOR_VERSION&lt;span style="color:#e6db74"&gt;/install-no-webhook.yaml&amp;#34;&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;kubectl apply -f operator-and-crds.yaml
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;kubectl -n vm rollout status deployment vm-operator --watch&lt;span style="color:#f92672"&gt;=&lt;/span&gt;true
&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;h2 id="验证"&gt;
 验证
 &lt;a class="anchor" href="#%e9%aa%8c%e8%af%81"&gt;#&lt;/a&gt;
&lt;/h2&gt;
&lt;div class="highlight"&gt;&lt;pre tabindex="0" style="color:#f8f8f2;background-color:#272822;-moz-tab-size:4;-o-tab-size:4;tab-size:4;-webkit-text-size-adjust:none;"&gt;&lt;code class="language-bash" data-lang="bash"&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;kubectl api-resources --api-group&lt;span style="color:#f92672"&gt;=&lt;/span&gt;operator.victoriametrics.com
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;OPERATOR_POD_NAME&lt;span style="color:#f92672"&gt;=&lt;/span&gt;&lt;span style="color:#66d9ef"&gt;$(&lt;/span&gt;kubectl get pod -l &lt;span style="color:#e6db74"&gt;&amp;#34;app.kubernetes.io/name=victoria-metrics-operator&amp;#34;&lt;/span&gt; -n vm -o jsonpath&lt;span style="color:#f92672"&gt;=&lt;/span&gt;&lt;span style="color:#e6db74"&gt;&amp;#34;{.items[0].metadata.name}&amp;#34;&lt;/span&gt;&lt;span style="color:#66d9ef"&gt;)&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;kubectl exec -n vm &lt;span style="color:#e6db74"&gt;&amp;#34;&lt;/span&gt;$OPERATOR_POD_NAME&lt;span style="color:#e6db74"&gt;&amp;#34;&lt;/span&gt; -- /app --printDefaults 2&amp;gt;&amp;amp;&lt;span style="color:#ae81ff"&gt;1&lt;/span&gt; | grep VMSINGLEDEFAULT_RESOURCE
&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;h2 id="说明"&gt;
 说明
 &lt;a class="anchor" href="#%e8%af%b4%e6%98%8e"&gt;#&lt;/a&gt;
&lt;/h2&gt;
&lt;ul&gt;
&lt;li&gt;推荐先确认 &lt;code&gt;vm&lt;/code&gt; 命名空间存在&lt;/li&gt;
&lt;li&gt;Operator 管理的资源尽量通过 CRD 修改，不直接改托管 Pod&lt;/li&gt;
&lt;/ul&gt;</description></item><item><title/><link>https://dlliang14.github.io/web-publicNotes/k8s-vm-vmagent%E9%87%87%E9%9B%86/</link><pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate><guid>https://dlliang14.github.io/web-publicNotes/k8s-vm-vmagent%E9%87%87%E9%9B%86/</guid><description>&lt;h1 id="k8s-vm-vmagent采集"&gt;
 k8s-vm-vmagent采集
 &lt;a class="anchor" href="#k8s-vm-vmagent%e9%87%87%e9%9b%86"&gt;#&lt;/a&gt;
&lt;/h1&gt;
&lt;p&gt;[[k8s-使用vm监控]]&lt;/p&gt;
&lt;h2 id="创建-vmagent"&gt;
 创建 VMAgent
 &lt;a class="anchor" href="#%e5%88%9b%e5%bb%ba-vmagent"&gt;#&lt;/a&gt;
&lt;/h2&gt;
&lt;div class="highlight"&gt;&lt;pre tabindex="0" style="color:#f8f8f2;background-color:#272822;-moz-tab-size:4;-o-tab-size:4;tab-size:4;-webkit-text-size-adjust:none;"&gt;&lt;code class="language-yaml" data-lang="yaml"&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#f92672"&gt;apiVersion&lt;/span&gt;: &lt;span style="color:#ae81ff"&gt;operator.victoriametrics.com/v1beta1&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#f92672"&gt;kind&lt;/span&gt;: &lt;span style="color:#ae81ff"&gt;VMAgent&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#f92672"&gt;metadata&lt;/span&gt;:
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#f92672"&gt;name&lt;/span&gt;: &lt;span style="color:#ae81ff"&gt;demo&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#f92672"&gt;namespace&lt;/span&gt;: &lt;span style="color:#ae81ff"&gt;vm&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#f92672"&gt;spec&lt;/span&gt;:
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#f92672"&gt;selectAllByDefault&lt;/span&gt;: &lt;span style="color:#66d9ef"&gt;true&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#f92672"&gt;remoteWrite&lt;/span&gt;:
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; - &lt;span style="color:#f92672"&gt;url&lt;/span&gt;: &lt;span style="color:#e6db74"&gt;&amp;#34;http://vmsingle-demo.vm.svc:8428/api/v1/write&amp;#34;&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;div class="highlight"&gt;&lt;pre tabindex="0" style="color:#f8f8f2;background-color:#272822;-moz-tab-size:4;-o-tab-size:4;tab-size:4;-webkit-text-size-adjust:none;"&gt;&lt;code class="language-bash" data-lang="bash"&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;kubectl -n vm apply -f vmagent-demo.yaml
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;kubectl -n vm wait --for&lt;span style="color:#f92672"&gt;=&lt;/span&gt;jsonpath&lt;span style="color:#f92672"&gt;=&lt;/span&gt;&lt;span style="color:#e6db74"&gt;&amp;#39;{.status.updateStatus}&amp;#39;&lt;/span&gt;&lt;span style="color:#f92672"&gt;=&lt;/span&gt;operational vmagent/demo
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;kubectl -n vm rollout status deployment vmagent-demo --watch&lt;span style="color:#f92672"&gt;=&lt;/span&gt;true
&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;h2 id="配置抓取规则-vmservicescrape"&gt;
 配置抓取规则 VMServiceScrape
 &lt;a class="anchor" href="#%e9%85%8d%e7%bd%ae%e6%8a%93%e5%8f%96%e8%a7%84%e5%88%99-vmservicescrape"&gt;#&lt;/a&gt;
&lt;/h2&gt;
&lt;div class="highlight"&gt;&lt;pre tabindex="0" style="color:#f8f8f2;background-color:#272822;-moz-tab-size:4;-o-tab-size:4;tab-size:4;-webkit-text-size-adjust:none;"&gt;&lt;code class="language-yaml" data-lang="yaml"&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#f92672"&gt;apiVersion&lt;/span&gt;: &lt;span style="color:#ae81ff"&gt;operator.victoriametrics.com/v1beta1&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#f92672"&gt;kind&lt;/span&gt;: &lt;span style="color:#ae81ff"&gt;VMServiceScrape&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#f92672"&gt;metadata&lt;/span&gt;:
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#f92672"&gt;name&lt;/span&gt;: &lt;span style="color:#ae81ff"&gt;demo-app-service-scrape&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#f92672"&gt;spec&lt;/span&gt;:
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#f92672"&gt;selector&lt;/span&gt;:
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#f92672"&gt;matchLabels&lt;/span&gt;:
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#f92672"&gt;app.kubernetes.io/name&lt;/span&gt;: &lt;span style="color:#ae81ff"&gt;demo-app&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#f92672"&gt;endpoints&lt;/span&gt;:
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; - &lt;span style="color:#f92672"&gt;port&lt;/span&gt;: &lt;span style="color:#ae81ff"&gt;http&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;div class="highlight"&gt;&lt;pre tabindex="0" style="color:#f8f8f2;background-color:#272822;-moz-tab-size:4;-o-tab-size:4;tab-size:4;-webkit-text-size-adjust:none;"&gt;&lt;code class="language-yaml" data-lang="yaml"&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#f92672"&gt;apiVersion&lt;/span&gt;: &lt;span style="color:#ae81ff"&gt;operator.victoriametrics.com/v1beta1&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#f92672"&gt;kind&lt;/span&gt;: &lt;span style="color:#ae81ff"&gt;VMServiceScrape&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#f92672"&gt;metadata&lt;/span&gt;:
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#f92672"&gt;name&lt;/span&gt;: &lt;span style="color:#ae81ff"&gt;gpu-dcgm-service-scrape&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#f92672"&gt;namespace&lt;/span&gt;: &lt;span style="color:#ae81ff"&gt;gpu-operator&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#f92672"&gt;spec&lt;/span&gt;:
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#f92672"&gt;selector&lt;/span&gt;:
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#f92672"&gt;matchLabels&lt;/span&gt;:
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#f92672"&gt;app&lt;/span&gt;: &lt;span style="color:#ae81ff"&gt;nvidia-dcgm-exporter&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#f92672"&gt;endpoints&lt;/span&gt;:
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; - &lt;span style="color:#f92672"&gt;port&lt;/span&gt;: &lt;span style="color:#ae81ff"&gt;gpu-metrics&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;h2 id="查看-targets"&gt;
 查看 targets
 &lt;a class="anchor" href="#%e6%9f%a5%e7%9c%8b-targets"&gt;#&lt;/a&gt;
&lt;/h2&gt;
&lt;div class="highlight"&gt;&lt;pre tabindex="0" style="color:#f8f8f2;background-color:#272822;-moz-tab-size:4;-o-tab-size:4;tab-size:4;-webkit-text-size-adjust:none;"&gt;&lt;code class="language-bash" data-lang="bash"&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;VMAGENT_SVC_NAME&lt;span style="color:#f92672"&gt;=&lt;/span&gt;&lt;span style="color:#66d9ef"&gt;$(&lt;/span&gt;kubectl get svc -n vm -l &lt;span style="color:#e6db74"&gt;&amp;#34;app.kubernetes.io/name=vmagent&amp;#34;&lt;/span&gt; -o jsonpath&lt;span style="color:#f92672"&gt;=&lt;/span&gt;&lt;span style="color:#e6db74"&gt;&amp;#34;{.items[0].metadata.name}&amp;#34;&lt;/span&gt;&lt;span style="color:#66d9ef"&gt;)&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;kubectl port-forward -n vm svc/$VMAGENT_SVC_NAME 8429:8429
&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;ul&gt;
&lt;li&gt;Targets 页面: &lt;code&gt;http://127.0.0.1:8429/targets&lt;/code&gt;&lt;/li&gt;
&lt;/ul&gt;</description></item><item><title/><link>https://dlliang14.github.io/web-publicNotes/k8s-vm-vmsingle%E5%AD%98%E5%82%A8/</link><pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate><guid>https://dlliang14.github.io/web-publicNotes/k8s-vm-vmsingle%E5%AD%98%E5%82%A8/</guid><description>&lt;h1 id="k8s-vm-vmsingle存储"&gt;
 k8s-vm-vmsingle存储
 &lt;a class="anchor" href="#k8s-vm-vmsingle%e5%ad%98%e5%82%a8"&gt;#&lt;/a&gt;
&lt;/h1&gt;
&lt;p&gt;[[k8s-使用vm监控]]&lt;/p&gt;
&lt;h2 id="创建-vmsingle"&gt;
 创建 VMSingle
 &lt;a class="anchor" href="#%e5%88%9b%e5%bb%ba-vmsingle"&gt;#&lt;/a&gt;
&lt;/h2&gt;
&lt;div class="highlight"&gt;&lt;pre tabindex="0" style="color:#f8f8f2;background-color:#272822;-moz-tab-size:4;-o-tab-size:4;tab-size:4;-webkit-text-size-adjust:none;"&gt;&lt;code class="language-yaml" data-lang="yaml"&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#f92672"&gt;apiVersion&lt;/span&gt;: &lt;span style="color:#ae81ff"&gt;operator.victoriametrics.com/v1beta1&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#f92672"&gt;kind&lt;/span&gt;: &lt;span style="color:#ae81ff"&gt;VMSingle&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#f92672"&gt;metadata&lt;/span&gt;:
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#f92672"&gt;name&lt;/span&gt;: &lt;span style="color:#ae81ff"&gt;demo&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#f92672"&gt;namespace&lt;/span&gt;: &lt;span style="color:#ae81ff"&gt;vm&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#f92672"&gt;spec&lt;/span&gt;:
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#f92672"&gt;retentionPeriod&lt;/span&gt;: &lt;span style="color:#e6db74"&gt;&amp;#34;1&amp;#34;&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#f92672"&gt;storage&lt;/span&gt;:
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#f92672"&gt;accessModes&lt;/span&gt;:
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; - &lt;span style="color:#ae81ff"&gt;ReadWriteMany&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#f92672"&gt;resources&lt;/span&gt;:
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#f92672"&gt;requests&lt;/span&gt;:
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#f92672"&gt;storage&lt;/span&gt;: &lt;span style="color:#ae81ff"&gt;10Gi&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#f92672"&gt;storageClassName&lt;/span&gt;: &lt;span style="color:#ae81ff"&gt;annotations-path-archive&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;div class="highlight"&gt;&lt;pre tabindex="0" style="color:#f8f8f2;background-color:#272822;-moz-tab-size:4;-o-tab-size:4;tab-size:4;-webkit-text-size-adjust:none;"&gt;&lt;code class="language-bash" data-lang="bash"&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;kubectl apply -f vmsingle-demo.yaml
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;kubectl -n vm wait --for&lt;span style="color:#f92672"&gt;=&lt;/span&gt;jsonpath&lt;span style="color:#f92672"&gt;=&lt;/span&gt;&lt;span style="color:#e6db74"&gt;&amp;#39;{.status.updateStatus}&amp;#39;&lt;/span&gt;&lt;span style="color:#f92672"&gt;=&lt;/span&gt;operational vmsingle/demo
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;kubectl -n vm rollout status deployment vmsingle-demo --watch&lt;span style="color:#f92672"&gt;=&lt;/span&gt;true
&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;h2 id="对外访问"&gt;
 对外访问
 &lt;a class="anchor" href="#%e5%af%b9%e5%a4%96%e8%ae%bf%e9%97%ae"&gt;#&lt;/a&gt;
&lt;/h2&gt;
&lt;div class="highlight"&gt;&lt;pre tabindex="0" style="color:#f8f8f2;background-color:#272822;-moz-tab-size:4;-o-tab-size:4;tab-size:4;-webkit-text-size-adjust:none;"&gt;&lt;code class="language-bash" data-lang="bash"&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;VMSINGLE_SVC_NAME&lt;span style="color:#f92672"&gt;=&lt;/span&gt;&lt;span style="color:#66d9ef"&gt;$(&lt;/span&gt;kubectl get svc -n vm -l &lt;span style="color:#e6db74"&gt;&amp;#34;app.kubernetes.io/name=vmsingle&amp;#34;&lt;/span&gt; -o jsonpath&lt;span style="color:#f92672"&gt;=&lt;/span&gt;&lt;span style="color:#e6db74"&gt;&amp;#34;{.items[0].metadata.name}&amp;#34;&lt;/span&gt;&lt;span style="color:#66d9ef"&gt;)&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;kubectl port-forward -n vm svc/$VMSINGLE_SVC_NAME 38428:8428 --address 0.0.0.0
&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;ul&gt;
&lt;li&gt;UI: &lt;code&gt;http://&amp;lt;node-ip&amp;gt;:38428/vmui&lt;/code&gt;&lt;/li&gt;
&lt;li&gt;如需转发到外部主机，可用 &lt;code&gt;socat&lt;/code&gt; 做 TCP 转发&lt;/li&gt;
&lt;/ul&gt;
&lt;h2 id="排查"&gt;
 排查
 &lt;a class="anchor" href="#%e6%8e%92%e6%9f%a5"&gt;#&lt;/a&gt;
&lt;/h2&gt;
&lt;div class="highlight"&gt;&lt;pre tabindex="0" style="color:#f8f8f2;background-color:#272822;-moz-tab-size:4;-o-tab-size:4;tab-size:4;-webkit-text-size-adjust:none;"&gt;&lt;code class="language-bash" data-lang="bash"&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;kubectl get pods -A -o jsonpath&lt;span style="color:#f92672"&gt;=&lt;/span&gt;&lt;span style="color:#e6db74"&gt;&amp;#39;{range .items[*]}{.metadata.namespace}{&amp;#34;/&amp;#34;}{.metadata.name}{&amp;#34;\t&amp;#34;}{range .spec.volumes[*].persistentVolumeClaim}{.claimName}{&amp;#34;\n&amp;#34;}{end}{end}&amp;#39;&lt;/span&gt; | grep &lt;span style="color:#e6db74"&gt;&amp;#34;vmsingle-demo&amp;#34;&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;</description></item><item><title/><link>https://dlliang14.github.io/web-publicNotes/k8s-vm-%E5%91%8A%E8%AD%A6%E4%B8%8E%E9%89%B4%E6%9D%83/</link><pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate><guid>https://dlliang14.github.io/web-publicNotes/k8s-vm-%E5%91%8A%E8%AD%A6%E4%B8%8E%E9%89%B4%E6%9D%83/</guid><description>&lt;h1 id="k8s-vm-告警与鉴权"&gt;
 k8s-vm-告警与鉴权
 &lt;a class="anchor" href="#k8s-vm-%e5%91%8a%e8%ad%a6%e4%b8%8e%e9%89%b4%e6%9d%83"&gt;#&lt;/a&gt;
&lt;/h1&gt;
&lt;p&gt;[[k8s-使用vm监控]]&lt;/p&gt;
&lt;h2 id="告警组件关系"&gt;
 告警组件关系
 &lt;a class="anchor" href="#%e5%91%8a%e8%ad%a6%e7%bb%84%e4%bb%b6%e5%85%b3%e7%b3%bb"&gt;#&lt;/a&gt;
&lt;/h2&gt;
&lt;ul&gt;
&lt;li&gt;VMAlertmanager: 告警通知路由&lt;/li&gt;
&lt;li&gt;VMAlert: 规则评估与告警状态&lt;/li&gt;
&lt;li&gt;VMRule: 告警规则定义&lt;/li&gt;
&lt;/ul&gt;
&lt;h2 id="最小流程"&gt;
 最小流程
 &lt;a class="anchor" href="#%e6%9c%80%e5%b0%8f%e6%b5%81%e7%a8%8b"&gt;#&lt;/a&gt;
&lt;/h2&gt;
&lt;ol&gt;
&lt;li&gt;创建 &lt;code&gt;VMAlertmanager&lt;/code&gt;&lt;/li&gt;
&lt;li&gt;创建 &lt;code&gt;VMAlert&lt;/code&gt;，配置 datasource/remoteWrite/notifier&lt;/li&gt;
&lt;li&gt;创建 &lt;code&gt;VMRule&lt;/code&gt;，定义 &lt;code&gt;expr&lt;/code&gt; 与阈值&lt;/li&gt;
&lt;/ol&gt;
&lt;h2 id="访问-vmalert"&gt;
 访问 VMAlert
 &lt;a class="anchor" href="#%e8%ae%bf%e9%97%ae-vmalert"&gt;#&lt;/a&gt;
&lt;/h2&gt;
&lt;div class="highlight"&gt;&lt;pre tabindex="0" style="color:#f8f8f2;background-color:#272822;-moz-tab-size:4;-o-tab-size:4;tab-size:4;-webkit-text-size-adjust:none;"&gt;&lt;code class="language-bash" data-lang="bash"&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;VMALERT_SVC_NAME&lt;span style="color:#f92672"&gt;=&lt;/span&gt;&lt;span style="color:#66d9ef"&gt;$(&lt;/span&gt;kubectl get svc -n vm -l &lt;span style="color:#e6db74"&gt;&amp;#34;app.kubernetes.io/name=vmalert&amp;#34;&lt;/span&gt; -o jsonpath&lt;span style="color:#f92672"&gt;=&lt;/span&gt;&lt;span style="color:#e6db74"&gt;&amp;#34;{.items[0].metadata.name}&amp;#34;&lt;/span&gt;&lt;span style="color:#66d9ef"&gt;)&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;kubectl port-forward -n vm svc/$VMALERT_SVC_NAME 8080:8080
&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;ul&gt;
&lt;li&gt;&lt;code&gt;http://127.0.0.1:8080/vmalert/groups&lt;/code&gt;&lt;/li&gt;
&lt;/ul&gt;
&lt;h2 id="开启鉴权vmauth--vmuser"&gt;
 开启鉴权（VMAuth + VMUser）
 &lt;a class="anchor" href="#%e5%bc%80%e5%90%af%e9%89%b4%e6%9d%83vmauth--vmuser"&gt;#&lt;/a&gt;
&lt;/h2&gt;
&lt;ul&gt;
&lt;li&gt;VMAuth 负责统一入口与认证&lt;/li&gt;
&lt;li&gt;VMUser 负责账号与路径级授权（按 targetRefs + paths）&lt;/li&gt;
&lt;/ul&gt;
&lt;div class="highlight"&gt;&lt;pre tabindex="0" style="color:#f8f8f2;background-color:#272822;-moz-tab-size:4;-o-tab-size:4;tab-size:4;-webkit-text-size-adjust:none;"&gt;&lt;code class="language-yaml" data-lang="yaml"&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#f92672"&gt;apiVersion&lt;/span&gt;: &lt;span style="color:#ae81ff"&gt;operator.victoriametrics.com/v1beta1&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#f92672"&gt;kind&lt;/span&gt;: &lt;span style="color:#ae81ff"&gt;VMAuth&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#f92672"&gt;metadata&lt;/span&gt;:
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#f92672"&gt;name&lt;/span&gt;: &lt;span style="color:#ae81ff"&gt;demo&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#f92672"&gt;spec&lt;/span&gt;:
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#f92672"&gt;selectAllByDefault&lt;/span&gt;: &lt;span style="color:#66d9ef"&gt;true&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#f92672"&gt;ingress&lt;/span&gt;:
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#f92672"&gt;class_name&lt;/span&gt;: &lt;span style="color:#e6db74"&gt;&amp;#39;nginx&amp;#39;&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#f92672"&gt;host&lt;/span&gt;: &lt;span style="color:#ae81ff"&gt;victoriametrics.mycompany.com&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;div class="highlight"&gt;&lt;pre tabindex="0" style="color:#f8f8f2;background-color:#272822;-moz-tab-size:4;-o-tab-size:4;tab-size:4;-webkit-text-size-adjust:none;"&gt;&lt;code class="language-bash" data-lang="bash"&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;kubectl -n vm get secret vmuser-demo -o jsonpath&lt;span style="color:#f92672"&gt;=&lt;/span&gt;&lt;span style="color:#e6db74"&gt;&amp;#34;{.data.username}&amp;#34;&lt;/span&gt; | base64 --decode
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;kubectl -n vm get secret vmuser-demo -o jsonpath&lt;span style="color:#f92672"&gt;=&lt;/span&gt;&lt;span style="color:#e6db74"&gt;&amp;#34;{.data.password}&amp;#34;&lt;/span&gt; | base64 --decode
&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;h2 id="安全建议"&gt;
 安全建议
 &lt;a class="anchor" href="#%e5%ae%89%e5%85%a8%e5%bb%ba%e8%ae%ae"&gt;#&lt;/a&gt;
&lt;/h2&gt;
&lt;ul&gt;
&lt;li&gt;不要把明文密钥写入笔记或 Git&lt;/li&gt;
&lt;li&gt;使用 K8s Secret + 外部密钥管理（如 Vault/KMS）&lt;/li&gt;
&lt;/ul&gt;</description></item><item><title/><link>https://dlliang14.github.io/web-publicNotes/k8s-vm-%E5%A4%87%E4%BB%BD%E6%81%A2%E5%A4%8D/</link><pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate><guid>https://dlliang14.github.io/web-publicNotes/k8s-vm-%E5%A4%87%E4%BB%BD%E6%81%A2%E5%A4%8D/</guid><description>&lt;h1 id="k8s-vm-备份恢复"&gt;
 k8s-vm-备份恢复
 &lt;a class="anchor" href="#k8s-vm-%e5%a4%87%e4%bb%bd%e6%81%a2%e5%a4%8d"&gt;#&lt;/a&gt;
&lt;/h1&gt;
&lt;p&gt;[[k8s-使用vm监控]]&lt;/p&gt;
&lt;h2 id="版本能力"&gt;
 版本能力
 &lt;a class="anchor" href="#%e7%89%88%e6%9c%ac%e8%83%bd%e5%8a%9b"&gt;#&lt;/a&gt;
&lt;/h2&gt;
&lt;ul&gt;
&lt;li&gt;企业版：支持自动化 &lt;code&gt;vmbackupmanager&lt;/code&gt;&lt;/li&gt;
&lt;li&gt;开源版：通常用定时任务 + 对象存储（S3 兼容）手动编排&lt;/li&gt;
&lt;/ul&gt;
&lt;h2 id="开源版建议流程"&gt;
 开源版建议流程
 &lt;a class="anchor" href="#%e5%bc%80%e6%ba%90%e7%89%88%e5%bb%ba%e8%ae%ae%e6%b5%81%e7%a8%8b"&gt;#&lt;/a&gt;
&lt;/h2&gt;
&lt;ol&gt;
&lt;li&gt;对 VMSingle 做快照&lt;/li&gt;
&lt;li&gt;上传快照到 S3 兼容存储&lt;/li&gt;
&lt;li&gt;故障时下载并手动恢复&lt;/li&gt;
&lt;/ol&gt;
&lt;h2 id="secret-管理原则"&gt;
 Secret 管理原则
 &lt;a class="anchor" href="#secret-%e7%ae%a1%e7%90%86%e5%8e%9f%e5%88%99"&gt;#&lt;/a&gt;
&lt;/h2&gt;
&lt;ul&gt;
&lt;li&gt;只在 Kubernetes Secret 中保存凭据&lt;/li&gt;
&lt;li&gt;笔记中只保留模板，不写真实 &lt;code&gt;access-key&lt;/code&gt;/&lt;code&gt;secret-key&lt;/code&gt;&lt;/li&gt;
&lt;/ul&gt;
&lt;div class="highlight"&gt;&lt;pre tabindex="0" style="color:#f8f8f2;background-color:#272822;-moz-tab-size:4;-o-tab-size:4;tab-size:4;-webkit-text-size-adjust:none;"&gt;&lt;code class="language-yaml" data-lang="yaml"&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#f92672"&gt;apiVersion&lt;/span&gt;: &lt;span style="color:#ae81ff"&gt;v1&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#f92672"&gt;kind&lt;/span&gt;: &lt;span style="color:#ae81ff"&gt;Secret&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#f92672"&gt;metadata&lt;/span&gt;:
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#f92672"&gt;name&lt;/span&gt;: &lt;span style="color:#ae81ff"&gt;vmbackup-credentials&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#f92672"&gt;namespace&lt;/span&gt;: &lt;span style="color:#ae81ff"&gt;vm&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#f92672"&gt;type&lt;/span&gt;: &lt;span style="color:#ae81ff"&gt;Opaque&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#f92672"&gt;stringData&lt;/span&gt;:
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#f92672"&gt;access-key&lt;/span&gt;: &lt;span style="color:#e6db74"&gt;&amp;#34;&amp;lt;REDACTED&amp;gt;&amp;#34;&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#f92672"&gt;secret-key&lt;/span&gt;: &lt;span style="color:#e6db74"&gt;&amp;#34;&amp;lt;REDACTED&amp;gt;&amp;#34;&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;h2 id="文档入口"&gt;
 文档入口
 &lt;a class="anchor" href="#%e6%96%87%e6%a1%a3%e5%85%a5%e5%8f%a3"&gt;#&lt;/a&gt;
&lt;/h2&gt;
&lt;ul&gt;
&lt;li&gt;
&lt;a href="https://docs.victoriametrics.com/operator/api/#vmbackup" rel="noopener"&gt;VMBackup API&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;&lt;code&gt;kubectl explain vmsingle.spec&lt;/code&gt;&lt;/li&gt;
&lt;/ul&gt;</description></item><item><title/><link>https://dlliang14.github.io/web-publicNotes/k8s-%E4%BD%BF%E7%94%A8vm%E7%9B%91%E6%8E%A7/</link><pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate><guid>https://dlliang14.github.io/web-publicNotes/k8s-%E4%BD%BF%E7%94%A8vm%E7%9B%91%E6%8E%A7/</guid><description>&lt;h1 id="大纲-k8s使用vm监控"&gt;
 大纲-k8s使用vm监控
 &lt;a class="anchor" href="#%e5%a4%a7%e7%ba%b2-k8s%e4%bd%bf%e7%94%a8vm%e7%9b%91%e6%8e%a7"&gt;#&lt;/a&gt;
&lt;/h1&gt;
&lt;h2 id="operator-与基础组件"&gt;
 Operator 与基础组件
 &lt;a class="anchor" href="#operator-%e4%b8%8e%e5%9f%ba%e7%a1%80%e7%bb%84%e4%bb%b6"&gt;#&lt;/a&gt;
&lt;/h2&gt;
&lt;ul&gt;
&lt;li&gt;[[k8s-vm-operator安装]]&lt;/li&gt;
&lt;/ul&gt;
&lt;h2 id="数据存储"&gt;
 数据存储
 &lt;a class="anchor" href="#%e6%95%b0%e6%8d%ae%e5%ad%98%e5%82%a8"&gt;#&lt;/a&gt;
&lt;/h2&gt;
&lt;ul&gt;
&lt;li&gt;[[k8s-vm-vmsingle存储]]&lt;/li&gt;
&lt;/ul&gt;
&lt;h2 id="指标采集"&gt;
 指标采集
 &lt;a class="anchor" href="#%e6%8c%87%e6%a0%87%e9%87%87%e9%9b%86"&gt;#&lt;/a&gt;
&lt;/h2&gt;
&lt;ul&gt;
&lt;li&gt;[[k8s-vm-vmagent采集]]&lt;/li&gt;
&lt;/ul&gt;
